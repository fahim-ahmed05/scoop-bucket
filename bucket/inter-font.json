{
    "version": "4.1",
    "description": "The Inter typeface family, carefully crafted & designed for computer screens.",
    "homepage": "https://rsms.me/inter/",
    "license": "OFL-1.1",
    "url": "https://github.com/rsms/inter/releases/download/v4.1/Inter-4.1.zip",
    "hash": "9883FDD4A49D4FB66BD8177BA6625EF9A64AA45899767DDE3D36AA425756B11E",
    "post_install": [
        "$fontsDir = \"$env:LOCALAPPDATA\\Microsoft\\Windows\\Fonts\"",
        "if (!(Test-Path $fontsDir)) { New-Item $fontsDir -Type Directory -Force | Out-Null }",
        "Get-ChildItem $dir -File | Where-Object { $_.Extension -match '\\.(ttf|ttc)' } | ForEach-Object {",
        "    $fontName = $_.Name",
        "    Copy-Item $_.FullName \"$fontsDir\\$fontName\" -Force",
        "    $regName = $_.BaseName + ' (TrueType)'",
        "    New-ItemProperty -Path 'HKCU:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $regName -Value $fontName -PropertyType String -Force | Out-Null",
        "}",
        "Write-Host 'Inter fonts installed! You may need to restart your terminal or apps to see them.' -ForegroundColor Green"
    ],
    "uninstaller": {
        "script": [
            "$fontsDir = \"$env:LOCALAPPDATA\\Microsoft\\Windows\\Fonts\"",
            "Get-ChildItem $dir -File | Where-Object { $_.Extension -match '\\.(ttf|ttc)' } | ForEach-Object {",
            "    $fontName = $_.Name",
            "    $regName = $_.BaseName + ' (TrueType)'",
            "    Remove-ItemProperty -Path 'HKCU:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $regName -ErrorAction SilentlyContinue",
            "    Remove-Item \"$fontsDir\\$fontName\" -ErrorAction SilentlyContinue",
            "}"
        ]
    },
    "checkver": {
        "github": "https://github.com/rsms/inter"
    },
    "autoupdate": {
        "url": "https://github.com/rsms/inter/releases/download/v$version/Inter-$version.zip"
    }
}
