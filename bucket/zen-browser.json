{
    "version": "1.21.5b",
    "description": "Zen is a firefox-based browser with the aim of pushing your productivity to a new level!",
    "homepage": "https://www.zen-browser.app/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.5b/zen.installer.exe#/dl.7z",
            "hash": "3b0056c395e6da3f80e245e43f37fc9fc97e333570580585ea0285a10f7bc219"
        },
        "arm64": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.5b/zen.installer-arm64.exe#/dl.7z",
            "hash": "4cca67aefdc05eab11e433fe0fad3acfb7be184cf5f2510926a9aa71b9a3de03"
        }
    },
    "post_install": [
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "extract_dir": "core",
    "shortcuts": [
        [
            "zen.exe",
            "Zen Browser"
        ],
        [
            "private_browsing.exe",
            "Zen Private Browsing"
        ],
        [
            "zen.exe",
            "Zen Browser Profile Manager",
            "-P"
        ]
    ],
    "persist": "distribution",
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/tags",
        "regex": "releases/tag/([ab\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer-arm64.exe#/dl.7z"
            }
        }
    }
}
